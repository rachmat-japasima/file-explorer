{
  "name": "@windows-explorer/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun --env-file=../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/infrastructure/database/migrate.ts",
    "db:seed": "bun --env-file=../.env src/infrastructure/database/seed.ts",
    "db:migrate:prod": "bun dist/infrastructure/database/migrate.js",
    "db:seed:prod": "bun dist/infrastructure/database/seed.js",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.1.0",
    "@elysiajs/swagger": "^1.1.0",
    "@sinclair/typebox": "^0.34.35",
    "@windows-explorer/shared": "workspace:*",
    "drizzle-orm": "^0.30.0",
    "elysia": "^1.4.28",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.21.0",
    "typescript": "^5.3.0"
  }
}
