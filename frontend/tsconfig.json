{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "types": [],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@windows-explorer/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "src/env.d.ts",
    "vite.config.ts"
  ]
}