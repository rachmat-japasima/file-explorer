# ============================================================
# .env.example — copy to .env and fill in values
# ============================================================

# PostgreSQL
POSTGRES_USER=explorer
POSTGRES_PASSWORD=explorer_secret
POSTGRES_DB=explorer

# Backend
DATABASE_URL=postgresql://explorer:explorer_secret@localhost:5432/explorer
PORT=3000
FRONTEND_URL=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:3000
VITE_APP_TITLE=app-name
